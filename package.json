{
  "name": "@mukundakatta/roman-mcp",
  "version": "0.1.0",
  "mcpName": "io.github.MukundaKatta/roman",
  "description": "MCP server: convert between Arabic numerals and Roman numerals (1-3999).",
  "type": "module",
  "bin": {
    "mcp-roman": "dist/server.js"
  },
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "test": "node --test --import tsx test/*.test.ts",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "cursor",
    "cline",
    "windsurf",
    "zed",
    "roman",
    "numerals",
    "convert"
  ],
  "author": "Mukunda Katta <mukunda.vjcs6@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/MukundaKatta/roman-mcp#readme",
  "bugs": {
    "url": "https://github.com/MukundaKatta/roman-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MukundaKatta/roman-mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
